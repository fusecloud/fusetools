# .env.example — copy to .env and fill in values

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Google Suite
GSUITE_TOKEN_PATH=    # path to GSuite OAuth credentials JSON
GSUITE_SCOPES=        # comma-separated scopes to pass as the `scopes` param (e.g. https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/drive)

# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

