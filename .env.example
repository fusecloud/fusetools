# .env.example — copy to .env and fill in values

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Firebase
FIREBASE_TOKEN_PATH=  # path to Firebase service account JSON

# Google Suite
GSUITE_TOKEN_PATH=    # path to GSuite OAuth credentials JSON
GSUITE_SCOPES=        # comma-separated scopes

# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# GCP
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_PATH=
